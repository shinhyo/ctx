    {
      "id": "codex",
      "display_name": "Codex",
      "priority": "p0",
      "status": "local_import",
      "capture_provider": "codex",
      "implemented_paths": [
        {
          "kind": "native_import",
          "source_format": "codex_session_jsonl_tree",
          "fidelity": "imported",
          "proof": ["ctx sources", "ctx import --provider codex"],
          "notes": ["Reads supported local session JSONL files under ~/.codex/sessions."]
        },
        {
          "kind": "native_import",
          "source_format": "codex_history_jsonl",
          "fidelity": "partial",
          "proof": ["ctx sources", "ctx import --provider codex"],
          "notes": ["Reads ~/.codex/history.jsonl when present."]
        }
      ],
      "history_locations": ["~/.codex/sessions", "~/.codex/history.jsonl"],
      "imports_existing_history": true,
      "captures_new_runs_passively": false,
      "child_sessions_supported": true,
      "fidelity": {
        "user_prompts": true,
        "assistant_messages": true,
        "tool_calls": true,
        "tool_output": false,
        "command_output": false,
        "files_touched": false,
        "artifacts": false,
        "model_identity": true,
        "costs": false,
        "token_usage": false,
        "parent_child_session_edges": true
      },
      "redaction_notes": ["Search/context output is local/private; review before sharing."],
      "live_e2e": {
        "status": "manual_opt_in_local_history",
        "default_enabled": false,
        "provider_command_execution": false,
        "api_key_env_passed_to_ctx": false,
        "temporary_ctx_data_root": true,
        "script": "scripts/release-provider-live-e2e-lanes.sh run codex",
        "required_env": [
          "CTX_LIVE_PROVIDER_E2E=1",
          "CTX_LIVE_PROVIDER_ACCEPT_LOCAL_HISTORY=1",
          "CTX_LIVE_PROVIDER_CODEX=1",
          "CTX_LIVE_PROVIDER_CODEX_SESSIONS_PATH",
          "CTX_LIVE_PROVIDER_CODEX_QUERY or CTX_LIVE_PROVIDER_QUERY"
        ],
        "optional_env": [
          "CTX_LIVE_PROVIDER_CODEX_HISTORY_PATH"
        ],
        "artifacts": ["live-e2e.json", "live-e2e.md"],
        "redaction": [
          "aggregate and oracle counts only",
          "no raw transcripts",
          "no raw snippets",
          "no raw queries",
          "no raw source paths",
          "provider-filter, citation, source_exists, and retrieval oracle counts only"
        ]
      },
      "public_docs": "docs/providers.md",
      "tests": [
        "crates/ctx-cli/tests/cli.rs",
        "crates/work-record-capture/src/lib.rs",
        "tests/fixtures/provider/codex.jsonl",
        "tests/fixtures/provider-history/codex-sessions",
        "tests/fixtures/provider-history/codex-rich-sessions"
      ],
      "fixture_paths": [
        "tests/fixtures/provider/codex.jsonl",
        "tests/fixtures/provider-history/codex-sessions",
        "tests/fixtures/provider-history/codex-rich-sessions"
      ]
    },
