{
  "schema_version": 1,
  "kind": "r2_artifact_layout",
  "publishing": false,
  "package": "ctx",
  "version": "0.1.0",
  "default_bucket": "ctx-release-artifacts",
  "bucket_env": "CTX_RELEASE_R2_BUCKET",
  "prefix_env": "CTX_RELEASE_R2_PREFIX",
  "public_base_url_env": "CTX_RELEASE_PUBLIC_BASE_URL",
  "prefix_template": "ctx/releases/release-candidate/v0.1.0/<git-commit>",
  "objects": [
    {
      "platform": "linux-x64",
      "target_triple": "x86_64-unknown-linux-gnu",
      "object": "ctx-0.1.0-x86_64-unknown-linux-gnu"
    },
    {
      "platform": "macos-arm64",
      "target_triple": "aarch64-apple-darwin",
      "object": "ctx-0.1.0-aarch64-apple-darwin"
    },
    {
      "platform": "macos-x64",
      "target_triple": "x86_64-apple-darwin",
      "object": "ctx-0.1.0-x86_64-apple-darwin"
    },
    {
      "platform": "windows-x64",
      "target_triple": "x86_64-pc-windows-gnu",
      "object": "ctx-0.1.0-x86_64-pc-windows-gnu.exe"
    },
    {
      "platform": "freebsd-x64",
      "target_triple": "x86_64-unknown-freebsd",
      "object": "ctx-0.1.0-x86_64-unknown-freebsd"
    },
    {
      "platform": "installer",
      "object": "install.sh",
      "source": "scripts/install.sh"
    },
    {
      "platform": "installer",
      "object": "install.ps1",
      "source": "scripts/install.ps1"
    },
    {
      "platform": "all",
      "object": "ctx-release-metadata.env"
    },
    {
      "platform": "all",
      "object": "checksums.sha256"
    },
    {
      "platform": "all",
      "object": "release-candidate-manifest.json"
    }
  ],
  "freebsd_x64": {
    "status": "native_release_proof_required",
    "target_triple": "x86_64-unknown-freebsd",
    "release_dry_run_manifest": "artifacts/buildkite/release-dry-run/freebsd-x64/manifest.json",
    "release_dry_run_metadata": "artifacts/buildkite/release-dry-run/freebsd-x64/ctx-release-metadata.env"
  }
}
